<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. The Compose UI supplies its own colors; this theme
         keeps the splash/window background dark to avoid a white flash on launch. -->
    <style name="Theme.Divert" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>
</resources>
